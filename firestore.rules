rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }
    function uidUnchanged() {
      return !('userId' in request.resource.data) || request.resource.data.userId == request.auth.uid;
    }
    function isAdmin() {
      return isAuthenticated() &&
        (
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
          (request.auth.token.email == "lucasgutemberg39@gmail.com" && request.auth.token.email_verified == true)
        );
    }

    // Test Collection (for connection testing)
    match /test/{docId} {
      allow read: if isAuthenticated();
    }

    // User Profiles
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && request.resource.data.role == 'user';
      allow update: if (isOwner(userId) && request.resource.data.role == resource.data.role) || isAdmin();
    }

    // Edicts
    match /edicts/{edictId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if (isDocOwner() && uidUnchanged()) || isAdmin();
      allow delete: if isDocOwner() || isAdmin();
    }

    // Certificates
    match /certificates/{certId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if (isDocOwner() && uidUnchanged()) || isAdmin();
      allow delete: if isDocOwner() || isAdmin();
    }

    // Companies
    match /companies/{companyId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if (isDocOwner() && uidUnchanged()) || isAdmin();
      allow delete: if isDocOwner() || isAdmin();
    }

    // Proposals
    match /proposals/{proposalId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if (isDocOwner() && uidUnchanged()) || isAdmin();
      allow delete: if isDocOwner() || isAdmin();
    }
  }
}
